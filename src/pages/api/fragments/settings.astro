---
import db from "../../../lib/db";
export const partial = true;

const panels = await db.getPanelsWithCounts();
const categories = await db.getCategoriesWithPanel();
const backups = await db.getBackups(10);
---

<main
    id="grid"
    class="p-8 flex-1 overflow-y-auto max-w-[1200px] mx-auto w-full"
>
    <div class="flex flex-col lg:flex-row gap-8 items-start w-full">
        <!-- ── COLUMN 1: Appearance & Quotes ────────────────── -->
        <div class="flex flex-col gap-6 flex-1 min-w-0 w-full">
            <!-- Appearance -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-6"
            >
                <div class="flex items-center gap-2.5 mb-5">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><circle cx="12" cy="12" r="4"></circle><path
                            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
                        ></path></svg
                    >
                    <h3 class="text-base font-bold m-0 text-[var(--text)]">
                        Appearance
                    </h3>
                </div>
                <div class="grid grid-cols-3 gap-3">
                    <button
                        class="flex flex-col items-center gap-2 p-3 rounded-xl border border-[var(--border)] bg-transparent cursor-pointer transition-all duration-200 text-[12px] font-semibold text-[var(--muted)] hover:border-white/30 [&.active]:border-[var(--accent)] [&.active]:text-[var(--accent)] [&.active]:bg-[var(--accent)]/10"
                        @click="setTheme('light')"
                        :class="{ active: theme === 'light' }"
                    >
                        <div
                            class="w-full aspect-[4/3] rounded-lg shadow-sm border border-white/10"
                            style="background:#ffffff;"
                        >
                        </div>
                        <span>Light</span>
                    </button>
                    <button
                        class="flex flex-col items-center gap-2 p-3 rounded-xl border border-[var(--border)] bg-transparent cursor-pointer transition-all duration-200 text-[12px] font-semibold text-[var(--muted)] hover:border-white/30 [&.active]:border-[var(--accent)] [&.active]:text-[var(--accent)] [&.active]:bg-[var(--accent)]/10"
                        @click="setTheme('dark')"
                        :class="{ active: theme === 'dark' }"
                    >
                        <div
                            class="w-full aspect-[4/3] rounded-lg shadow-sm border border-white/10"
                            style="background:#0f172a;"
                        >
                        </div>
                        <span>Dark</span>
                    </button>
                    <button
                        class="flex flex-col items-center gap-2 p-3 rounded-xl border border-[var(--border)] bg-transparent cursor-pointer transition-all duration-200 text-[12px] font-semibold text-[var(--muted)] hover:border-white/30 [&.active]:border-[var(--accent)] [&.active]:text-[var(--accent)] [&.active]:bg-[var(--accent)]/10"
                        @click="setTheme('system')"
                        :class="{ active: theme === 'system' }"
                    >
                        <div
                            class="w-full aspect-[4/3] rounded-lg shadow-sm border border-white/10"
                            style="background:linear-gradient(135deg,#fff 50%,#0f172a 50%);"
                        >
                        </div>
                        <span>System</span>
                    </button>
                </div>
            </div>

            <!-- Quote Display -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-6"
            >
                <div class="flex items-center gap-2.5 mb-5">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><path
                            d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
                        ></path><path
                            d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"
                        ></path></svg
                    >
                    <h3 class="text-base font-bold m-0 text-[var(--text)]">
                        Quote Display
                    </h3>
                </div>
                <p class="text-[13px] text-[var(--muted)] leading-relaxed mb-5">
                    Quotes rotate on page load and every 30 minutes.
                </p>

                <div
                    class="text-[11px] font-bold text-[var(--muted)] uppercase tracking-wider mb-2.5"
                >
                    Collection
                </div>
                <div class="flex flex-col gap-2">
                    <button
                        class="relative flex items-center gap-3 p-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] cursor-pointer text-left transition-all duration-200 hover:border-white/30 [&.active]:border-[var(--accent)] [&.active]:bg-white/5"
                        @click="setQuotePack('founders')"
                        :class="{ active: quotePack === 'founders' }"
                    >
                        <span class="text-2xl">🇺🇸</span>
                        <div class="flex-1 min-w-0">
                            <div
                                class="text-[13px] font-semibold text-[var(--text)]"
                            >
                                American Founders
                            </div>
                            <div
                                class="text-[11px] text-[var(--muted)] mt-0.5 whitespace-nowrap overflow-hidden text-ellipsis"
                            >
                                Washington, Jefferson, Franklin &amp; more
                            </div>
                        </div>
                        <div
                            class="w-2.5 h-2.5 rounded-full bg-[var(--accent)] shrink-0"
                            x-show="quotePack === 'founders'"
                            style="display:none;"
                        >
                        </div>
                    </button>
                    <button
                        class="relative flex items-center gap-3 p-3 rounded-xl border border-[var(--border)] bg-[var(--surface)] cursor-pointer text-left transition-all duration-200 hover:border-white/30 [&.active]:border-[var(--accent)] [&.active]:bg-white/5"
                        @click="setQuotePack('rumi')"
                        :class="{ active: quotePack === 'rumi' }"
                    >
                        <span class="text-2xl">🌙</span>
                        <div class="flex-1 min-w-0">
                            <div
                                class="text-[13px] font-semibold text-[var(--text)]"
                            >
                                Rumi
                            </div>
                            <div
                                class="text-[11px] text-[var(--muted)] mt-0.5 whitespace-nowrap overflow-hidden text-ellipsis"
                            >
                                Mystical poems &amp; proverbs
                            </div>
                        </div>
                        <div
                            class="w-2.5 h-2.5 rounded-full bg-[var(--accent)] shrink-0"
                            x-show="quotePack === 'rumi'"
                            style="display:none;"
                        >
                        </div>
                    </button>
                </div>

                <div
                    class="text-[11px] font-bold text-[var(--muted)] uppercase tracking-wider mb-2.5"
                    style="margin-top:20px;"
                >
                    Position
                </div>
                <div class="flex gap-2">
                    <button
                        class="flex-1 flex items-center justify-center gap-2 p-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] cursor-pointer transition-all duration-200 text-[13px] font-semibold text-[var(--muted)] hover:border-white/40 [&.active]:border-[var(--accent)] [&.active]:text-[var(--accent)] [&.active]:bg-[var(--accent)]/10"
                        @click="setQuotePosition('top')"
                        :class="{ active: quotePosition === 'top' }"
                    >
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            ><polyline points="17 11 12 6 7 11"></polyline><line
                                x1="12"
                                y1="18"
                                x2="12"
                                y2="6"></line></svg
                        >
                        Top
                    </button>
                    <button
                        class="flex-1 flex items-center justify-center gap-2 p-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] cursor-pointer transition-all duration-200 text-[13px] font-semibold text-[var(--muted)] hover:border-white/40 [&.active]:border-[var(--accent)] [&.active]:text-[var(--accent)] [&.active]:bg-[var(--accent)]/10"
                        @click="setQuotePosition('bottom')"
                        :class="{ active: quotePosition === 'bottom' }"
                    >
                        <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            ><polyline points="7 13 12 18 17 13"
                            ></polyline><line x1="12" y1="6" x2="12" y2="18"
                            ></line></svg
                        >
                        Bottom
                    </button>
                </div>
            </div>

            <!-- Import Bookmarks -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-4"
            >
                <div class="flex items-center gap-4">
                    <span
                        class="w-10 h-10 rounded-[10px] bg-white/5 flex items-center justify-center text-xl shrink-0"
                        style="padding: 6px; background: rgba(59, 130, 246, 0.1); border-radius: 8px; color: var(--accent);"
                    >
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"
                            ></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    </span>
                    <div style="flex:1;">
                        <span
                            class="block text-[14px] font-bold text-[var(--text)]"
                            >Import Data</span
                        >
                        <span
                            class="block text-[11px] text-[var(--muted)] mt-0.5"
                            >Upload Netscape HTML Bookmarks</span
                        >
                    </div>
                    <button
                        class="flex items-center justify-center gap-2 w-full p-2.5 bg-[var(--accent)] text-white rounded-lg font-semibold text-sm border-none cursor-pointer transition-colors duration-200 mb-4 hover:bg-[var(--accent-hover)]"
                        style="width:auto; padding: 6px 12px; font-size: 13px;"
                        @click="modalOpen = true; modalTitle = 'Import Bookmarks'"
                        hx-get="/api/fragments/import-modal"
                        hx-target="#modal-content"
                        hx-swap="innerHTML"
                    >
                        Import
                    </button>
                </div>
            </div>

            <!-- About -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-4"
            >
                <div class="flex items-center gap-4">
                    <span
                        class="w-10 h-10 rounded-[10px] bg-white/5 flex items-center justify-center text-xl shrink-0"
                        >🚀</span
                    >
                    <div>
                        <span
                            class="block text-[14px] font-bold text-[var(--text)]"
                            >Mission Control</span
                        >
                        <span
                            class="block text-[11px] font-medium text-[var(--muted)] px-1.5 py-0.5 bg-[var(--surface-hover)] rounded mt-1 w-max"
                            >v1.0.0</span
                        >
                    </div>
                </div>
            </div>
        </div>

        <!-- ── COLUMN 2: Backups & Categories ──────────────── -->
        <div class="flex flex-col gap-6 flex-1 min-w-0 w-full">
            <!-- Backups -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-6"
            >
                <div class="flex items-center gap-2.5 mb-5">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"
                        ></path><polyline points="17 8 12 3 7 8"
                        ></polyline><line x1="12" y1="3" x2="12" y2="15"
                        ></line></svg
                    >
                    <h3 class="text-base font-bold m-0 text-[var(--text)]">
                        Backups
                    </h3>
                    <span
                        class="text-[11px] px-2 py-0.5 bg-[var(--surface-hover)] rounded-full text-[var(--muted)]"
                        >Last 10</span
                    >
                </div>
                <button
                    class="flex items-center justify-center gap-2 w-full p-2.5 bg-[var(--accent)] text-white rounded-lg font-semibold text-sm border-none cursor-pointer transition-colors duration-200 mb-4 hover:bg-[var(--accent-hover)]"
                    hx-post="/api/backups"
                    hx-target="#backup-list"
                    hx-swap="outerHTML"
                >
                    <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        ><path d="M12 5v14M5 12h14"></path></svg
                    >
                    Create Snapshot Now
                </button>
                <div
                    id="backup-list"
                    class="flex flex-col gap-2"
                    style="max-height: 250px;"
                >
                    {
                        backups.length === 0 ? (
                            <div class="flex flex-col items-center justify-center py-8 text-center text-[var(--muted)] text-[13px] italic gap-3 border border-dashed border-[var(--border)] rounded-xl">
                                <svg
                                    width="28"
                                    height="28"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                >
                                    <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                                    <polyline points="17 8 12 3 7 8" />
                                    <line x1="12" y1="3" x2="12" y2="15" />
                                </svg>
                                No backups yet
                            </div>
                        ) : (
                            backups.map((b) => (
                                <div
                                    class="flex items-center justify-between p-3 bg-transparent border border-[var(--border)] rounded-xl transition-colors duration-200 hover:border-white/30"
                                    id={`backup-${b.id}`}
                                >
                                    <div class="flex flex-col min-w-0">
                                        <span class="text-[13px] font-semibold text-[var(--text)] whitespace-nowrap overflow-hidden text-ellipsis">
                                            {b.label}
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
                                            onclick={`if(confirm('Restore this backup? Current data will be replaced.')) { 
                                            fetch('/api/backups/${b.id}/restore', { method: 'POST' })
                                                .then(() => { 
                                                    document.body.dispatchEvent(new Event('refresh'));
                                                    document.body.dispatchEvent(new Event('refreshSidebar'));
                                                });
                                        }`}
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                                                <path d="M3 3v5h5" />
                                            </svg>
                                        </button>
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-red-500/10 hover:!text-red-500"
                                            hx-delete={`/api/backups/${b.id}`}
                                            hx-target={`#backup-${b.id}`}
                                            hx-swap="outerHTML"
                                            hx-confirm="Delete this backup?"
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M18 6L6 18M6 6l12 12" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            ))
                        )
                    }
                </div>
            </div>

            <!-- Category Management -->
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-6"
                style="flex:1;"
            >
                <div class="flex items-center gap-2.5 mb-5">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><rect x="3" y="3" width="7" height="7" rx="1"
                        ></rect><rect x="14" y="3" width="7" height="7" rx="1"
                        ></rect><rect x="3" y="14" width="7" height="7" rx="1"
                        ></rect><rect x="14" y="14" width="7" height="7" rx="1"
                        ></rect></svg
                    >
                    <h3 class="text-base font-bold m-0 text-[var(--text)]">
                        Categories
                    </h3>
                    <span
                        class="text-[11px] px-2 py-0.5 bg-[var(--surface-hover)] rounded-full text-[var(--muted)]"
                        >{categories.length} total</span
                    >
                </div>
                <div class="flex flex-col gap-2">
                    {
                        categories.length === 0 ? (
                            <div class="flex flex-col items-center justify-center py-8 text-center text-[var(--muted)] text-[13px] italic gap-3 border border-dashed border-[var(--border)] rounded-xl">
                                <svg
                                    width="28"
                                    height="28"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                >
                                    <rect
                                        x="3"
                                        y="3"
                                        width="7"
                                        height="7"
                                        rx="1"
                                    />
                                    <rect
                                        x="14"
                                        y="3"
                                        width="7"
                                        height="7"
                                        rx="1"
                                    />
                                    <rect
                                        x="3"
                                        y="14"
                                        width="7"
                                        height="7"
                                        rx="1"
                                    />
                                    <rect
                                        x="14"
                                        y="14"
                                        width="7"
                                        height="7"
                                        rx="1"
                                    />
                                </svg>
                                No categories yet
                            </div>
                        ) : (
                            categories.map((cat) => (
                                <div class="flex items-center justify-between p-3 bg-transparent border border-[var(--border)] rounded-xl transition-colors duration-200 hover:border-white/30">
                                    <div class="flex flex-col min-w-0">
                                        <span class="text-[13px] font-semibold text-[var(--text)] whitespace-nowrap overflow-hidden text-ellipsis">
                                            {cat.name}
                                        </span>
                                        <span class="text-[11px] text-[var(--muted)] mt-1">
                                            {cat.panel_name || "—"}
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
                                            hx-get={`/api/fragments/category-modal?id=${cat.id}`}
                                            hx-target="#modal-content"
                                            hx-swap="innerHTML"
                                            @click="modalOpen = true; modalTitle = 'Edit Category'"
                                            title="Edit"
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M12 20h9" />
                                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                                            </svg>
                                        </button>
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-red-500/10 hover:!text-red-500"
                                            hx-get={`/api/fragments/delete-confirm-modal?type=category&id=${cat.id}&name=${encodeURIComponent(cat.name)}`}
                                            hx-target="#modal-content"
                                            hx-swap="innerHTML"
                                            @click.stop="modalOpen = true; modalTitle = 'Delete Category'"
                                            title="Delete"
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            ))
                        )
                    }
                </div>
            </div>
        </div>

        <!-- ── COLUMN 3: Panel Management ──────────────────── -->
        <div class="flex flex-col gap-6 flex-1 min-w-0 w-full">
            <div
                class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-[var(--border)] rounded-[20px] p-6"
                style="flex:1;"
            >
                <div class="flex items-center gap-2.5 mb-5">
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
                        ></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg
                    >
                    <h3 class="text-base font-bold m-0 text-[var(--text)]">
                        Panels
                    </h3>
                    <span
                        class="text-[11px] px-2 py-0.5 bg-[var(--surface-hover)] rounded-full text-[var(--muted)]"
                        >{panels.length} total</span
                    >
                </div>
                <!-- Warning hint for panels -->
                <p
                    class="text-[13px] text-[var(--muted)] leading-relaxed mb-5"
                    style="color:#ef4444; opacity:0.8;"
                >
                    Deleting a panel deletes all its categories and links!
                </p>

                <div class="flex flex-col gap-2">
                    {
                        panels.length === 0 ? (
                            <div class="flex flex-col items-center justify-center py-8 text-center text-[var(--muted)] text-[13px] italic gap-3 border border-dashed border-[var(--border)] rounded-xl">
                                <svg
                                    width="28"
                                    height="28"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                >
                                    <rect
                                        x="3"
                                        y="3"
                                        width="18"
                                        height="18"
                                        rx="2"
                                        ry="2"
                                    />
                                    <line x1="9" y1="3" x2="9" y2="21" />
                                </svg>
                                No panels yet
                            </div>
                        ) : (
                            panels.map((pan) => (
                                <div class="flex items-center justify-between p-3 bg-transparent border border-[var(--border)] rounded-xl transition-colors duration-200 hover:border-white/30">
                                    <div class="flex flex-col min-w-0">
                                        <span class="text-[13px] font-semibold text-[var(--text)] whitespace-nowrap overflow-hidden text-ellipsis">
                                            {pan.name}
                                        </span>
                                        <span class="text-[11px] text-[var(--muted)] mt-1">
                                            {pan.category_count}{" "}
                                            {pan.category_count === 1
                                                ? "category"
                                                : "categories"}
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-1">
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
                                            hx-get={`/api/fragments/panel-modal?id=${pan.id}`}
                                            hx-target="#modal-content"
                                            hx-swap="innerHTML"
                                            @click="modalOpen = true; modalTitle = 'Edit Panel'"
                                            title="Edit"
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M12 20h9" />
                                                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                                            </svg>
                                        </button>
                                        <button
                                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-red-500/10 hover:!text-red-500"
                                            hx-get={`/api/fragments/delete-confirm-modal?type=panel&id=${pan.id}&name=${encodeURIComponent(pan.name)}`}
                                            hx-target="#modal-content"
                                            hx-swap="innerHTML"
                                            @click.stop="modalOpen = true; modalTitle = 'Delete Panel'"
                                            title="Delete"
                                        >
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                            >
                                                <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" />
                                            </svg>
                                        </button>
                                    </div>
                                </div>
                            ))
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</main>
