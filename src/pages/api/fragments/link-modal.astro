---
import db from "../../../lib/db";
import type { Link } from "../../../lib/db";

export const partial = true;

const id = Astro.url.searchParams.get("id");
const catId = Astro.url.searchParams.get("catId");

let link: Link | null = null;
if (id) {
  link = await db.getLink(id);
}

const categories = await db.getCategories();
const selectedCatId = link
  ? link.category_id
  : catId
    ? parseInt(catId)
    : categories[0]?.id;
const triggerEvents = `change, keyup delay:1s, paste delay:1s, keydown[key=='Enter']${link && link.url && !link.description ? ", load delay:100ms" : ""}`;
---

<form
  id="modal-form"
  hx-post={link ? `/api/links/${link.id}` : "/api/links"}
  hx-swap="none"
  @htmx:after-request="if (event.detail.target.id === 'modal-form') modalOpen = false"
  autocomplete="off"
>
  <div class="mb-5" id="name-wrapper">
    <label
      for="f-name"
      class="block text-[13px] font-semibold text-[var(--muted)] mb-1.5"
      >Name</label
    >
    <input
      id="f-name"
      type="text"
      name="name"
      value={link?.name || ""}
      placeholder="e.g. GitHub"
      required
      autofocus
      class="w-full px-3 py-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] text-[var(--text)] text-sm outline-none transition-colors duration-200 focus:border-[var(--accent)]"
    />
  </div>

  <div class="mb-5">
    <label
      for="f-url"
      class="block text-[13px] font-semibold text-[var(--muted)] mb-1.5"
      >URL</label
    >
    <input
      id="f-url"
      type="text"
      name="url"
      value={link?.url || ""}
      placeholder="https://…"
      hx-post="/api/links/metadata"
      hx-trigger={triggerEvents}
      hx-target="#name-wrapper"
      hx-include="#modal-form"
      hx-swap="innerHTML"
      @keydown.enter.prevent="htmx.trigger(this, 'change')"
      required
      class="w-full px-3 py-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] text-[var(--text)] text-sm outline-none transition-colors duration-200 focus:border-[var(--accent)]"
    />
  </div>

  <div class="mb-5">
    <label
      for="f-description"
      class="block text-[13px] font-semibold text-[var(--muted)] mb-1.5"
      >Description</label
    >
    <input
      id="f-description"
      type="text"
      name="description"
      value={link?.description || ""}
      placeholder="Short note…"
      class="w-full px-3 py-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] text-[var(--text)] text-sm outline-none transition-colors duration-200 focus:border-[var(--accent)]"
    />
  </div>

  <div class="mb-5">
    <label
      for="f-cat"
      class="block text-[13px] font-semibold text-[var(--muted)] mb-1.5"
      >Category</label
    >
    <select
      name="category_id"
      id="f-cat"
      class="w-full px-3 py-2.5 rounded-lg border border-[var(--border)] bg-[var(--surface)] text-[var(--text)] text-sm outline-none transition-colors duration-200 focus:border-[var(--accent)]"
    >
      {
        categories.map((c) => (
          <option value={c.id} selected={c.id === selectedCatId}>
            {c.name}
          </option>
        ))
      }
    </select>
  </div>

  <div class="flex justify-end gap-3 mt-8">
    <button
      type="button"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 bg-transparent text-[var(--muted)] border border-[var(--border)] hover:text-[var(--text)] hover:border-[var(--text)]"
      @click="modalOpen = false">Cancel</button
    >
    <button
      type="submit"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 border-none bg-[var(--accent)] text-white hover:bg-[var(--accent-hover)]"
      >Save</button
    >
  </div>
</form>
