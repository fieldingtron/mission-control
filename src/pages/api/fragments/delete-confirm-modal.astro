---
export const partial = true;

const type = Astro.url.searchParams.get("type");
const id = Astro.url.searchParams.get("id");
const name = Astro.url.searchParams.get("name");

let deleteUrl = "";
let target = "";
let message = "";

if (type === "panel") {
    deleteUrl = `/api/panels/${id}`;
    target = "body";
    message = `Are you sure you want to delete the panel "${name}"? This will permanently remove all categories and links inside it.`;
} else if (type === "category") {
    deleteUrl = `/api/categories/${id}`;
    target = `#cat-${id}`;
    message = `Are you sure you want to delete the category "${name}"?`;
} else if (type === "link") {
    deleteUrl = `/api/links/${id}`;
    target = `#link-${id}`;
    message = `Are you sure you want to delete this link?`;
}
---

<div x-data={`{ deleteUrl: '${deleteUrl}', id: '${id}' }`}>
    <p class="text-[15px] leading-relaxed text-[var(--text)] mb-6">{message}</p>

    <div class="flex justify-end gap-3 mt-8">
        <button
            type="button"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 bg-transparent text-[var(--muted)] border border-[var(--border)] hover:text-[var(--text)] hover:border-[var(--text)]"
            @click="modalOpen = false"
        >
            Cancel
        </button>

        {
            type === "panel" ? (
                <button
                    type="button"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 border-none bg-red-500 text-white hover:bg-red-600"
                    @click={`
                        modalOpen = false;
                        fetch(deleteUrl, { method: 'DELETE' }).then(() => {
                            if (window.playMoveSound) window.playMoveSound();
                            reloadSidebar();
                            const firstPanel = document.querySelector('.sidebar-tab[href]');
                            const firstId = firstPanel ? new URL(firstPanel.href).searchParams.get('panel') : '1';
                            if (firstId && firstId !== id) {
                                currentPanel = firstId;
                                history.replaceState(null, '', '/?panel=' + firstId);
                            } else {
                                currentPanel = '1';
                                history.replaceState(null, '', '/?panel=1');
                            }
                            reloadGrid();
                        });
                    `}
                >
                    Delete
                </button>
            ) : (
                <button
                    type="button"
                    class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold cursor-pointer transition-all duration-200 border-none bg-red-500 text-white hover:bg-red-600"
                    hx-delete={deleteUrl}
                    hx-target={target}
                    hx-swap="outerHTML"
                    @click="if (window.playMoveSound) window.playMoveSound(); modalOpen = false"
                >
                    Delete
                </button>
            )
        }
    </div>
</div>
