---
import db from "../../../lib/db";
export const partial = true;

const backups = await db.getBackups(10);
---

<div
    class="flex flex-col gap-2 max-h-[250px] overflow-y-auto pr-1"
    id="backup-list"
>
    {
        backups.length === 0 ? (
            <p class="flex flex-col items-center justify-center py-8 text-center text-[var(--muted)] text-[13px] italic gap-3 border border-dashed border-[var(--border)] rounded-xl">
                No backups yet. Create your first backup above.
            </p>
        ) : (
            backups.map((b) => (
                <div
                    class="flex items-center justify-between p-3 bg-transparent border border-[var(--border)] rounded-xl transition-colors duration-200 hover:border-white/30"
                    id={`backup-${b.id}`}
                >
                    <div class="flex flex-col min-w-0">
                        <span class="text-[13px] font-semibold text-[var(--text)] whitespace-nowrap overflow-hidden text-ellipsis">
                            {b.label}
                        </span>
                        <span class="text-[11px] text-[var(--muted)] mt-1">
                            {new Date(b.created_at + "Z").toLocaleString(
                                "en-US",
                                {
                                    month: "short",
                                    day: "numeric",
                                    hour: "2-digit",
                                    minute: "2-digit",
                                },
                            )}
                        </span>
                    </div>
                    <div class="flex items-center gap-1">
                        <button
                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
                            onclick={`if(confirm('Restore this backup? Your current data will be replaced.')) { 
                            fetch('/api/backups/${b.id}/restore', { method: 'POST' })
                                .then(r => r.json())
                                .then(() => { 
                                    document.body.dispatchEvent(new Event('refresh'));
                                    document.body.dispatchEvent(new Event('refreshSidebar'));
                                    htmx.ajax('GET', '/api/fragments/backup-list', { target: '#backup-list', swap: 'outerHTML' });
                                });
                        }`}
                            title="Restore this backup"
                        >
                            <svg
                                width="13"
                                height="13"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                                <path d="M3 3v5h5" />
                            </svg>
                        </button>
                        <button
                            class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-red-500/10 hover:!text-red-500"
                            hx-delete={`/api/backups/${b.id}`}
                            hx-target={`#backup-${b.id}`}
                            hx-swap="outerHTML"
                            hx-confirm="Delete this backup?"
                            title="Delete backup"
                        >
                            <svg
                                width="13"
                                height="13"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2" />
                            </svg>
                        </button>
                    </div>
                </div>
            ))
        )
    }
</div>
