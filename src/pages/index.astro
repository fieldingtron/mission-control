---
import db from "../lib/db";
import Category from "../components/Category.astro";
import Settings from "./api/fragments/settings.astro";
import { QUOTE_PACKS, getQuoteForTime } from "../lib/quotes";
// SSR: seed the initial quote with the Founders pack as fallback
// Client-side Alpine.js will pick up the saved pack from localStorage
const ssrQuote = getQuoteForTime("founders");

const url = new URL(Astro.request.url);
const currentPanelId = url.searchParams.get("panel") || "1";

// Get all panels for navigation
const panels = await db.getPanels();

let categories: any[] = [];
let links: any[] = [];

if (currentPanelId !== "settings") {
  // Initial data fetch for SSR
  categories = (await db.getCategories(currentPanelId)) as any[];
  links = (await db.getLinks()) as any[];
}

const data = categories.map((c) => ({
  ...c,
  links: links.filter((l) => l.category_id === c.id),
}));
