                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                class="rocket-icon"
              >
                <path
                  d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.71-2.13.71-2.13s-1.29 0-2.13-.71c-.13-.13-.43-.43-.58-.16z"
                ></path>
                <path d="M11.5 12.5L7 17"></path>
                <path d="M12 15l-3.5 3.5L5 15l3.5-3.5L12 15z"></path>
                <path
                  d="M17 7c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4z"
                ></path>
                <path d="M22 2l-3 3"></path>
              </svg>
              <h1 class="brand-title">MISSION CONTROL</h1>
            </div>
          </div>

          <div style="display: flex; align-items: center; gap: 20px;">
            <div class="search-box" style="width: 300px; border-radius: 8px;">
              <svg
                class="search-icon"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input
                type="search"
                name="q"
                x-model="searchQuery"
                placeholder="Search resources..."
                autocomplete="off"
                style="text-transform: none; font-weight: 400;"
              />
            </div>

            <div class="clock-display" x-text="clockText"></div>

            <button
              class="btn btn-primary"
              hx-get="/api/fragments/category-modal"
              hx-include="#active-panel-id"
              hx-target="#modal-content"
              hx-push-url="false"
              @click="modalOpen = true; modalTitle = 'New Category'"
              style="border-radius: 8px; border: none; padding: 8px 16px;"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
              >
                <path d="M12 5v14M5 12h14"></path>
              </svg>
              Add Category
            </button>
          </div>
        </div>

        <!-- Dashboard Grid -->
        <!-- Top Quote Banner (shown when position is 'top') -->
        <div
          class="quote-top-banner"
          x-show="quotePosition === 'top' && quoteText"
          style="display:none;"
        >
          <span class="quote-top-text" x-text="'\u201c' + quoteText + '\u201d'"
          ></span>
          <span class="quote-top-author" x-text="'\u2014 ' + quoteAuthor"
          ></span>
        </div>

        <div
          class="grid-container"
          style="flex: 1; overflow-y: auto; padding: 32px;"
        >
          {
            currentPanelId === "settings" ? (
              <Settings />
            ) : (
              <main
                id="grid"
                x-data
                x-init="
                Sortable.create($el, {
                  animation: 150,
                  handle: '.drag-handle-cat',
                  onEnd: async () => {
                    const ids = Array.from($el.children).map(el => el.getAttribute('data-id')).filter(id => id);
                    if (window.playMoveSound) window.playMoveSound();
                    await fetch('/api/categories/reorder', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ ids })
                    });
                    if (window.dashboardBc) window.dashboardBc.postMessage({ type: 'refresh' });
                  }
                });
              "
              >
                {data.length > 0 ? (
                  data.map((cat) => <Category category={cat} />)
                ) : (
                  <div class="empty-page">
                    <p>
                      No categories yet.
                      <br />
                      Click <strong>+ Category</strong> to get started.
                    </p>
                  </div>
                )}
              </main>
            )
          }
        </div>

        <footer
          class="main-footer"
          style="background: transparent; border: none; padding: 16px 32px; font-size: 12px; color: var(--muted);"
        >
          <!-- Rotating Quote Display (bottom position) -->
          <div
            class="quote-display"
            x-show="quotePosition === 'bottom' && quoteText"
            style="display:none;"
          >
            <span class="quote-text" x-text="'“' + quoteText + '”'"></span>
            <span class="quote-author" x-text="'— ' + quoteAuthor"></span>
          </div>
        </footer>
      </main>
    </div>
  </body>

  <style is:global>
    [x-cloak] {
      display: none !important;
    }
  </style>
</html>
