  <body
    x-data={`{
      modalOpen: false,
      modalTitle: '',
      clockText: '',
      searchQuery: '',
      currentPanel: '${currentPanelId}',
      sidebarCollapsed: localStorage.sidebarCollapsed === 'true',
      theme: localStorage.theme || 'system',
      dragOverPanel: null,
      quotePack: localStorage.quotePack || 'founders',
      quotePosition: localStorage.quotePosition || 'bottom',
      quoteText: (() => {
        try {
          const pack = (window.QUOTE_PACKS || {})[localStorage.quotePack || 'founders'] || (window.QUOTE_PACKS || {})['founders'];
          if (!pack) return '';
          return pack.quotes[Math.floor(Math.random() * pack.quotes.length)].text;
        } catch(e) { return ''; }
      })(),
      quoteAuthor: (() => {
        try {
          const pack = (window.QUOTE_PACKS || {})[localStorage.quotePack || 'founders'] || (window.QUOTE_PACKS || {})['founders'];
          if (!pack) return '';
          return pack.quotes[Math.floor(Math.random() * pack.quotes.length)].author;
        } catch(e) { return ''; }
      })(),
      refreshQuote() {
        const packs = window.QUOTE_PACKS;
        if (!packs) return;
        const pack = packs[this.quotePack] || packs['founders'];
        const idx = Math.floor(Math.random() * pack.quotes.length);
        this.quoteText = pack.quotes[idx].text;
        this.quoteAuthor = pack.quotes[idx].author;
      },
      setQuotePack(packId) {
        this.quotePack = packId;
        localStorage.quotePack = packId;
        this.refreshQuote();
      },
      setQuotePosition(pos) {
        this.quotePosition = pos;
        localStorage.quotePosition = pos;
      },
      setTheme(t) {
        this.theme = t;
        if (t === 'system') {
          localStorage.removeItem('theme');
          document.documentElement.removeAttribute('data-theme');
        } else {
          localStorage.theme = t;
          document.documentElement.setAttribute('data-theme', t);
        }
      },
      toggleSidebar() {
        this.sidebarCollapsed = !this.sidebarCollapsed;
        localStorage.sidebarCollapsed = this.sidebarCollapsed;
      },
      reloadGrid() {
        const activePanelEl = document.getElementById('active-panel-id');
        const panelToFetch = activePanelEl ? activePanelEl.value : this.currentPanel;
        htmx.ajax('GET', '/api/fragments/grid?panel=' + panelToFetch + '&_t=' + Date.now(), {target: '#grid', swap: 'outerHTML', pushUrl: false});
      },
      reloadSidebar() {
        const activePanelEl = document.getElementById('active-panel-id');
        const panelToFetch = activePanelEl ? activePanelEl.value : this.currentPanel;
        htmx.ajax('GET', '/api/fragments/sidebar-nav?panelId=' + panelToFetch + '&_t=' + Date.now(), {target: '#sidebar-nav-container', swap: 'innerHTML', pushUrl: false});
      },
      playMoveSound() {
        if (window.playMoveSound) window.playMoveSound();
      }
    }`}
    class="dashboard"
    x-init="
      const self = this;

      // Clock Update
      setInterval(() => {
        const now = new Date();
        self.clockText = now.toLocaleDateString('en-US', {
          weekday: 'short',
          year: 'numeric',
          month: 'short',
          day: 'numeric'
        }).toUpperCase() + ' · ' + now.toLocaleTimeString('en-US', { hour12: false });
      }, 1000);

      // System theme listener
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
        if (self.theme === 'system') {
          document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
        }
      });

      // Listen for HX-Trigger 'refresh' and 'refreshSidebar' events
      document.body.addEventListener('refresh', () => { self.reloadGrid(); });
      document.body.addEventListener('refreshSidebar', () => { self.reloadSidebar(); });

      // Cross-Tab Sync
      window.dashboardBc = new BroadcastChannel('dashboard-sync');
      window.dashboardBc.onmessage = (event) => {
        const data = event.data;
        if (data === 'refresh' || data.type === 'refresh') {
          self.reloadGrid();
          self.reloadSidebar();
        }
        if (data.type === 'theme' && data.theme !== self.theme) {
          self.theme = data.theme;
          if (self.theme === 'system') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            document.documentElement.setAttribute('data-theme', self.theme);
          }
        }
      };

      // Watch theme and broadcast
      $watch('theme', (val) => {
        if (window.dashboardBc) window.dashboardBc.postMessage({ type: 'theme', theme: val });
      });

      // Keyboard Shortcuts
      window.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || self.modalOpen) return;
        if (['1','2','3','4','5','6','7','8','9'].includes(e.key)) {
          const idx = parseInt(e.key) - 1;
          const tabs = document.querySelectorAll('.sidebar-tab');
          if (tabs[idx]) tabs[idx].click();
        }
      });

      // Global sound synthesizer
      window.playMoveSound = function() {
        try {
          const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
          const oscillator = audioCtx.createOscillator();
          const gainNode = audioCtx.createGain();

          oscillator.type = 'sine';
          oscillator.frequency.setValueAtTime(440, audioCtx.currentTime); 
          oscillator.frequency.exponentialRampToValueAtTime(880, audioCtx.currentTime + 0.05);

          gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
          gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);

          oscillator.connect(gainNode);
          gainNode.connect(audioCtx.destination);

          oscillator.start();
          oscillator.stop(audioCtx.currentTime + 0.1);
        } catch (e) {
          console.warn('Audio feedback failed', e);
        }
      };

      // Broadcast on successful mutations
      document.body.addEventListener('htmx:afterRequest', (evt) => {
        if (evt.detail.successful && evt.detail.requestConfig.verb !== 'get') {
          if (window.dashboardBc) window.dashboardBc.postMessage({ type: 'refresh' });
        }
      });

      // Quote: rotate every 30 minutes (initial quote is set synchronously in x-data)
      setInterval(() => { self.refreshQuote(); }, 1000 * 60 * 30);
    "
