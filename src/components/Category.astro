---
import Link from "./Link.astro";
const { category } = Astro.props;
---

<div
  class="bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] border border-white/20 rounded-[24px] overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 break-inside-avoid mb-5"
  id={`cat-${category.id}`}
  data-id={category.id}
  data-catname={category.name.toLowerCase()}
  x-show="!searchQuery || $el.dataset.catname.includes(searchQuery.toLowerCase()) || Array.from($el.querySelectorAll('.link-row')).some(l => (l.dataset.search || '').includes(searchQuery.toLowerCase()))"
  draggable="true"
  @dragstart={`event.dataTransfer.setData('categoryId', '${category.id}')`}
>
  <div
    class="flex items-center justify-between p-4 bg-transparent border-b border-white/10"
  >
    <div class="flex items-center gap-2.5">
      <span
        class="drag-handle-cat cursor-grab active:cursor-grabbing text-[var(--muted)] hover:text-[var(--text)] flex items-center p-1 rounded hover:bg-[var(--surface-hover)]"
      >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="9" cy="5" r="1"></circle><circle cx="9" cy="12" r="1"
          ></circle><circle cx="9" cy="19" r="1"></circle>
          <circle cx="15" cy="5" r="1"></circle><circle cx="15" cy="12" r="1"
          ></circle><circle cx="15" cy="19" r="1"></circle>
        </svg>
      </span>
      <span class="text-sm font-bold tracking-tight text-[var(--text)]"
        >{category.name}</span
      >
    </div>
    <div class="flex items-center gap-2">
      <button
        class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
        title="Add link"
        hx-get={`/api/fragments/link-modal?catId=${category.id}`}
        hx-target="#modal-content"
        @click="modalOpen = true; modalTitle = 'New Link'"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M12 5v14M5 12h14"></path>
        </svg>
      </button>
      <div
        class="relative inline-block"
        x-data="{ open: false }"
        @click.away="open = false"
      >
        <button
          class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
          title="More options"
          @click="open = !open"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"
            ></circle><circle cx="12" cy="19" r="1"></circle>
          </svg>
        </button>
        <div
          class="absolute right-0 top-full bg-[var(--surface)] backdrop-blur-xl backdrop-saturate-[1.8] min-w-[120px] shadow-xl border border-[var(--border)] rounded-lg z-20 mt-1 overflow-hidden"
          x-show="open"
          x-transition.opacity.duration.200ms
          style="display: none;"
          x-cloak
        >
          <button
            class="w-full px-3 py-2 text-left border-none bg-transparent text-[var(--text)] text-[13px] hover:bg-[var(--surface-hover)] cursor-pointer"
            hx-get={`/api/fragments/category-modal?id=${category.id}`}
            hx-target="#modal-content"
            @click="modalOpen = true; modalTitle = 'Rename Category'; open = false;"
          >
            Rename
          </button>
          <button
            class="w-full px-3 py-2 text-left border-none bg-transparent text-red-500 text-[13px] hover:bg-red-500/10 cursor-pointer"
            hx-get={`/api/fragments/delete-confirm-modal?type=category&id=${category.id}&name=${encodeURIComponent(category.name)}`}
            hx-target="#modal-content"
            @click="modalOpen = true; modalTitle = 'Delete Category'; open = false;"
          >
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>
  <ul
    class="list-none py-2 px-0"
    data-cat-id={category.id}
    x-data
    x-init="
    Sortable.create($el, {
      group: 'links',
      animation: 150,
      handle: '.drag-handle-link',
      onEnd: async (evt) => {
        const catId = evt.to.getAttribute('data-cat-id');
        const ids = Array.from(evt.to.children).map(el => el.getAttribute('data-id')).filter(id => id);
        if (window.playMoveSound) window.playMoveSound();
        await fetch('/api/links/reorder', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ categoryId: catId, ids })
        });
        if (window.dashboardBc) window.dashboardBc.postMessage({ type: 'refresh' });
      }
    });
  "
  >
    {
      category.links.length > 0 ? (
        category.links.map((l) => <Link link={l} />)
      ) : (
        <li class="py-3 px-4 text-[var(--muted)] text-[13px] text-center italic">
          No links yet
        </li>
      )
    }
  </ul>
</div>
