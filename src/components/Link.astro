---
const { link } = Astro.props;

function normalizeUrl(url) {
  const s = url.trim();
  return /^https?:\/\//i.test(s) ? s : `https://${s}`;
}

function getFavicon(url) {
  try {
    const domain = new URL(normalizeUrl(url)).hostname;
    return `https://www.google.com/s2/favicons?sz=32&domain=${domain}`;
  } catch {
    return "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAYAAAAf8/9hAAAAmUlEQVQ4T2NkoBAwUqifYfQA4z8G3PCoP/+BAsYKUAXofmBkoD78B7onmCDYAGSOfyD9IDf8Y2BgYPhPrAGMUAXofmBkID78ByUnmCDYAGSOfyD9IDf8Y2BgYPhPrAGMUAXofmBkID78ByUnmCDYAGSOfyD9IDf8Y2BgYPhPrAGMUAXofmBkID78ByUnmCDYAGSOfyD9IDf8Y2BgYPgPAGp9OR9ALp7PAAAAAElFTkSuQmCC";
  }
}
---

<li
  class="group flex items-center justify-between px-3 py-2 rounded-lg mb-0.5 transition-colors duration-200 hover:bg-[var(--surface-hover)]"
  id={`link-${link.id}`}
  data-id={link.id}
  data-search={`${link.name.toLowerCase()} ${link.url.toLowerCase()} ${link.description?.toLowerCase() || ""}`}
  x-show="!searchQuery || $el.dataset.search.includes(searchQuery.toLowerCase()) || $el.closest('.card').dataset.catname.includes(searchQuery.toLowerCase())"
>
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <span
      class="cursor-grab active:cursor-grabbing text-[var(--muted)] opacity-0 group-hover:opacity-50 hover:!opacity-100 hover:text-[var(--text)] hover:bg-[var(--surface-hover)] flex items-center p-0.5 rounded transition-opacity duration-200"
    >
      <svg
        width="10"
        height="10"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <circle cx="9" cy="5" r="1"></circle><circle cx="9" cy="12" r="1"
        ></circle><circle cx="9" cy="19" r="1"></circle>
        <circle cx="15" cy="5" r="1"></circle><circle cx="15" cy="12" r="1"
        ></circle><circle cx="15" cy="19" r="1"></circle>
      </svg>
    </span>
    <div
      class="w-6 h-6 flex items-center justify-center bg-white rounded-md p-1 shrink-0"
    >
      <img
        class="w-full h-full object-contain"
        src={getFavicon(link.url)}
        alt=""
        loading="lazy"
      />
    </div>
    <div class="flex flex-col min-w-0">
      <a
        href={link.url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[13px] font-semibold text-[var(--text)] no-underline whitespace-nowrap overflow-hidden text-ellipsis hover:underline hover:decoration-[var(--accent)]"
        >{link.name}</a
      >
      {
        link.description && (
          <p class="text-[11px] text-[var(--muted)] whitespace-nowrap overflow-hidden text-ellipsis mt-0.5">
            {link.description}
          </p>
        )
      }
    </div>
  </div>
  <div
    class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
  >
    <button
      class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:bg-[var(--surface-hover)] hover:text-[var(--text)]"
      title="Edit"
      hx-get={`/api/fragments/link-modal?id=${link.id}`}
      hx-target="#modal-content"
      @click="modalOpen = true; modalTitle = 'Edit Link'"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
        ></path>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
        ></path>
      </svg>
    </button>
    <button
      class="w-7 h-7 rounded-md border-none bg-transparent text-[var(--muted)] flex items-center justify-center cursor-pointer transition-all duration-200 hover:text-red-500 hover:bg-red-500/10"
      title="Delete"
      hx-get={`/api/fragments/delete-confirm-modal?type=link&id=${link.id}`}
      hx-target="#modal-content"
      @click="modalOpen = true; modalTitle = 'Delete Link'"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          d="M3 6h18m-2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
        ></path>
      </svg>
    </button>
  </div>
</li>
