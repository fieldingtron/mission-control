{
  "name": "link-dashboard",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "localhost": "dashboard.localhost",
  "scripts": {
    "dev": "node ./localhost-dev/bin/localhost-dev.js npm run dev:astro",
    "dev:astro": "NODE_OPTIONS=--experimental-sqlite astro dev",
    "postinstall": "node install.js",
    "setup": "node install.js",
    "build": "NODE_OPTIONS=--experimental-sqlite astro build",
    "preview": "NODE_OPTIONS=--experimental-sqlite astro preview",
    "test:db": "tsx src/scripts/verify-db.ts",
    "test:adapter": "NODE_OPTIONS=--experimental-sqlite npx tsx src/tests/db-adapter.test.ts"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^0.4.9",
    "@astrojs/node": "^9.0.0",
    "@libsql/client": "^0.17.0",
    "@tailwindcss/vite": "^4.2.1",
    "alpinejs": "^3.15.8",
    "astro": "^5.1.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  }
}